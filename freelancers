<link rel="icon" type="image/png" sizes="32x32" href="assets/img/icon_guia.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<link rel="stylesheet" href="styles.css">
<style>
.freelas-page { padding-top: var(--nav-h); }
.freelas-hero { background:var(--dark); padding:2.5rem 2rem; border-bottom:1px solid var(--border2); }
.freelas-layout { display:flex; gap:2rem; max-width:1140px; margin:0 auto; padding:2rem; align-items:flex-start; }
.freelas-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(240px,1fr)); gap:1.15rem; }
.fc { padding:1.5rem; text-align:center; position:relative; }
.fc-avatar-wrap { position:relative; display:inline-block; margin-bottom:0.85rem; }
.fc-online { position:absolute; bottom:3px; right:3px; width:13px; height:13px; background:var(--green); border-radius:50%; border:2px solid var(--card); }
.fc-name { font-size:1rem; font-weight:700; margin-bottom:0.2rem; }
.fc-role { font-size:0.8rem; color:var(--text-muted); margin-bottom:0.5rem; }
.fc-city { font-size:0.75rem; color:var(--text-dim); margin-bottom:0.6rem; }
.fc-rate { font-size:1rem; font-weight:700; color:var(--purple-light); margin-bottom:0.5rem; }
.fc-stars { font-size:0.82rem; margin-bottom:0.75rem; }
.fc-skills { display:flex; gap:0.3rem; justify-content:center; flex-wrap:wrap; margin-bottom:1rem; }
.freelas-sidebar { width:240px; flex-shrink:0; position:sticky; top:calc(var(--nav-h) + 1rem); }
.filters-body { background:var(--card); border:1px solid var(--border2); border-radius:var(--radius); padding:1.25rem; }
@media(max-width:900px){ .freelas-layout{ flex-direction:column; padding:1.25rem; } .freelas-sidebar{ width:100%; position:static; } }
</style>
</head>
<body>
